#!/bin/bash
# Genesi OS - update-mirrorlist
# Simplified mirrorlist update (rate-mirrors may not be available)

echo "==> Genesi OS: Updating mirrorlist..."

# Use reflector if available, otherwise use default mirrors
if command -v cachyos-rate-mirrors &> /dev/null; then
    echo "==> Using cachyos-rate-mirrors to rank mirrors..."
    cachyos-rate-mirrors || true
    
    # Also fetch CachyOS mirrors manually just to be safe
    curl -s "https://mirror.cachyos.org/cachyos-mirrorlist" -o /etc/pacman.d/cachyos-mirrorlist || true
    curl -s "https://mirror.cachyos.org/cachyos-v3-mirrorlist" -o /etc/pacman.d/cachyos-v3-mirrorlist || true
    curl -s "https://mirror.cachyos.org/cachyos-v4-mirrorlist" -o /etc/pacman.d/cachyos-v4-mirrorlist || true
    
elif command -v reflector &> /dev/null; then
    echo "==> Using reflector to rank mirrors..."
    reflector --latest 20 --protocol https --sort rate --save /etc/pacman.d/mirrorlist || true
elif command -v rate-mirrors &> /dev/null; then
    echo "==> Using rate-mirrors to rank mirrors..."
    rate-mirrors --allow-root arch > /etc/pacman.d/mirrorlist || true
else
    echo "==> No mirror ranking tool available, using default mirrors..."
    cat > /etc/pacman.d/mirrorlist << 'EOF'
##
## Arch Linux repository mirrorlist
##
Server = https://mirror.rackspace.com/archlinux/$repo/os/$arch
Server = https://mirrors.kernel.org/archlinux/$repo/os/$arch
Server = https://mirror.osbeck.com/archlinux/$repo/os/$arch
Server = https://geo.mirror.pkgbuild.com/$repo/os/$arch
EOF
fi

chmod 0644 /etc/pacman.d/mirrorlist 2>/dev/null || true
echo "==> Mirrorlist updated successfully"

# Always exit with success to prevent installation failure
exit 0